{
    "rewrites": [
        {
            "source": "/api/agents/:agent",
            "destination": "/api/agents-router?agent=:agent"
        },
        {
            "source": "/",
            "destination": "/agents/home.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
